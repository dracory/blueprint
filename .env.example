# ============================================================================
# Blueprint Environment Configuration
# ============================================================================
#
# This file contains all environment variables used by the application.
# Copy this file to .env and fill in the appropriate values for your environment.
#
# Environment Types:
#   - local: Local development
#   - development: Development server
#   - staging: Staging environment
#   - production: Production environment
#   - testing: Test environment
#
# Setup:
#   1. Copy this file to .env
#   2. Fill in required values
#   3. Run: task env-dev (for development) or task env-prod (for production)
# ============================================================================

# ============================================================================
# Application Configuration
# ============================================================================

# Application Environment
# The environment the application is running in.
# Valid values: local, development, staging, production, testing
# Required: true
APP_ENV="development"

# Application Name
# The name of your application, used in notifications and display.
# Default: Blueprint
APP_NAME="YOUR APP NAME"

# Application URL
# The base URL of your application, used for generating links.
# Example: https://example.com
# Required: true
APP_URL="http://127.0.0.1:32322"

# Application Host
# The host address the server will listen on.
# Examples: 0.0.0.0 (all interfaces), 127.0.0.1 (localhost only)
# Required: true
APP_HOST="127.0.0.1"

# Application Port
# The port the server will listen on.
# Required: true
APP_PORT="32322"

# Application Debug Mode
# When enabled, detailed error messages are shown. Disable in production.
# Valid values: true, false
# Default: false
# APP_DEBUG=true

# ============================================================================
# Database Configuration
# ============================================================================

# Database Driver
# The type of database to use.
# Valid values: sqlite, mysql, postgres
# Default: sqlite
DB_DRIVER="sqlite"

# Database Host (MySQL/PostgreSQL only)
# The database server host.
# Required when DB_DRIVER=mysql or postgres
DB_HOST=""

# Database Port (MySQL/PostgreSQL only)
# The database server port.
# Required when DB_DRIVER=mysql or postgres
DB_PORT=""

# Database Name
# The database name (MySQL/PostgreSQL) or file path (SQLite).
# For SQLite, use full path to .db file
# Required: true
DB_DATABASE="database.db"

# Database User (MySQL/PostgreSQL only)
# The database username.
# Required when DB_DRIVER=mysql or postgres
DB_USERNAME=""

# Database Password (MySQL/PostgreSQL only)
# The database password.
# Required when DB_DRIVER=mysql or postgres
DB_PASSWORD=""

# Database SSL Mode (PostgreSQL only)
# SSL mode for database connection.
# Valid values: disable, require, verify-ca, verify-full
# Default: disable
DB_SSL_MODE="disable"

# Database Charset (MySQL only)
# Character set for database connection.
# Valid values: utf8mb4, utf8
# Default: utf8mb4
DB_CHARSET="utf8mb4"

# Database Timezone
# Timezone for database operations.
# Examples: UTC, America/New_York, Europe/London
# Default: UTC
DB_TIMEZONE="UTC"

# Connection Pool Settings (optional - sensible defaults are applied per driver)
# DB_MAX_OPEN_CONNS=25          # max open connections (sqlite default: 1)
# DB_MAX_IDLE_CONNS=5           # max idle connections (sqlite default: 1)
# DB_CONN_MAX_LIFETIME_SECONDS=300  # max connection lifetime in seconds (sqlite default: 30)
# DB_CONN_MAX_IDLE_TIME_SECONDS=5   # max connection idle time in seconds

# Multi-connection (optional - neat database layer)
# DB_DEFAULT_CONNECTION=default  # default connection name (default: "default")
# DB_DSN=                        # direct DSN override (optional)
# DB_PREFIX=                     # table prefix (optional)
# DB_CONNECTIONS=                # future multi-connection JSON config

# ============================================================================
# Email Configuration
# ============================================================================

# Email Driver
# The email service driver to use.
# Valid values: smtp, mailgun, ses, sendgrid
# Default: smtp
MAIL_DRIVER="smtp"

# SMTP Host
# The SMTP server host.
# Required when MAIL_DRIVER=smtp
# Example for MailHog (development): localhost
# Example for production: smtp.mailtrap.io
MAIL_HOST="localhost"

# SMTP Port
# The SMTP server port.
# Required when MAIL_DRIVER=smtp
# Example for MailHog: 1025
# Example for production: 2525
MAIL_PORT="1025"

# SMTP Username
# The SMTP username.
# Required when MAIL_DRIVER=smtp
MAIL_USERNAME="not_required"

# SMTP Password
# The SMTP password.
# Required when MAIL_DRIVER=smtp
MAIL_PASSWORD="not_required"

# SMTP Encryption
# The encryption method for SMTP.
# Valid values: null, tls, ssl
# Default: null
MAIL_ENCRYPTION="null"

# Email From Address
# The default email address to send from.
# Required: true
MAIL_FROM_ADDRESS="YOUR_EMAIL"

# Email From Name
# The default name to send emails from.
# Required: true
MAIL_FROM_NAME="YOUR_NAME"

# ============================================================================
# Media Configuration
# ============================================================================

# Media Driver
# The storage driver to use for media files.
# Valid values: local, s3, gcs, sql
# Default: local
# MEDIA_DRIVER="s3"

# Media Key
# The storage access key (for S3/GCS).
# Required when MEDIA_DRIVER=s3 or gcs
# MEDIA_KEY="YOUR_MEDIA_KEY"

# Media Secret
# The storage secret key (for S3/GCS).
# Required when MEDIA_DRIVER=s3 or gcs
# WARNING: Keep this secret!
# MEDIA_SECRET="YOUR_MEDIA_SECRET"

# Media Endpoint
# Custom storage endpoint URL (for S3-compatible services).
# Optional
# Example: https://ams3.digitaloceanspaces.com/
# MEDIA_ENDPOINT="https://ams3.digitaloceanspaces.com/"

# Media Region
# The storage region (for S3/GCS).
# Required when MEDIA_DRIVER=s3 or gcs
# Example: AMS3
# MEDIA_REGION="AMS3"

# Media Bucket
# The storage bucket name (for S3/GCS).
# Required when MEDIA_DRIVER=s3 or gcs
# MEDIA_BUCKET="YOUR_BUCKET_NAME"

# Media URL
# Public URL base for media files.
# Required: true
# Example: https://YOUR_BUCKET_NAME.ams3.digitaloceanspaces.com
# MEDIA_URL="https://YOUR_BUCKET_NAME.ams3.digitaloceanspaces.com"


# ============================================================================
# LLM Configuration
# ============================================================================

# Anthropic API Key
# API key for Anthropic Claude models.
# Required when using Anthropic models
# ANTHROPIC_API_KEY="YOUR_API_KEY"

# Anthropic API Used
# Enable Anthropic API integration.
# Valid values: yes, no
# Default: no
# ANTHROPIC_API_USED="no"

# Anthropic Default Model
# Default Anthropic model to use.
# Example: claude-3-opus-20240229
# ANTHROPIC_API_DEFAULT_MODEL="YOUR_MODEL_ID"

# Google Gemini API Key
# API key for Google Gemini models.
# Required when using Gemini models
# GEMINI_API_KEY="YOUR_API_KEY"

# Gemini API Used
# Enable Gemini API integration.
# Valid values: yes, no
# Default: no
# GEMINI_API_USED="no"

# Gemini Default Model
# Default Gemini model to use.
# GEMINI_API_DEFAULT_MODEL="YOUR_MODEL_ID"

# OpenAI API Key
# API key for OpenAI GPT models.
# Required when using OpenAI models
# OPENAI_API_KEY="sk_YOUR_API_KEY"

# OpenAI API Used
# Enable OpenAI API integration.
# Valid values: yes, no
# Default: no
# OPENAI_API_USED="no"

# OpenAI Default Model
# Default OpenAI model to use.
# Example: gpt-4
# OPENAI_API_DEFAULT_MODEL="YOUR_MODEL_ID"

# OpenRouter API Key
# API key for OpenRouter (multi-provider API).
# Required when using OpenRouter
# OPENROUTER_API_KEY="YOUR_API_KEY"

# OpenRouter API Used
# Enable OpenRouter API integration.
# Valid values: yes, no
# Default: no
# OPENROUTER_API_USED="no"

# OpenRouter Default Model
# Default OpenRouter model to use.
# OPENROUTER_API_DEFAULT_MODEL="YOUR_MODEL_ID"

# Vertex AI Project ID
# Google Cloud project ID for Vertex AI.
# Required when using Vertex AI
# VERTEX_AI_API_PROJECT_ID="YOUR_PROJECT_ID"

# Vertex AI Region
# Google Cloud region for Vertex AI.
# Required when using Vertex AI
# Example: us-central1
# VERTEX_AI_API_REGION_ID="YOUR_REGION_ID"

# Vertex AI Model ID
# Vertex AI model ID to use.
# Required when using Vertex AI
# VERTEX_AI_API_MODEL_ID="YOUR_MODEL_ID"

# Vertex AI API Used
# Enable Vertex AI API integration.
# Valid values: yes, no
# Default: no
# VERTEX_AI_API_USED="no"

# ============================================================================
# Authentication Configuration
# ============================================================================

# Enable Registration
# Allow new users to register for an account.
# Valid values: yes, no
# Default: yes
AUTH_REGISTRATION_ENABLED="yes"

# Allowed Email Domains
# Comma-separated list of allowed email domains for registration.
# Leave empty to allow any email domain.
# Example: example.com,gmail.com
# AUTH_EMAILS_ALLOWED_ACCESS=""

# ============================================================================
# Payment Configuration
# ============================================================================

# Stripe Private Key
# Stripe secret key.
# Required when using Stripe payments
# WARNING: Keep this secret!
# STRIPE_KEY_PRIVATE="sk_YOUR_KEY"

# Stripe Public Key
# Stripe publishable key.
# Required when using Stripe payments
# STRIPE_KEY_PUBLIC="pk_YOUR_KEY"

# ============================================================================
# Security Configuration
# ============================================================================

# Enable Environment Encryption
# When enabled, environment variables can be encrypted using envenc.
# Valid values: yes, no
# Default: no
ENVENC_USED="no"

# Encryption Private Key
# The private key used for decrypting environment variables.
# Required when ENVENC_USED=yes
# WARNING: Keep this secret! Never commit to version control.
ENVENC_KEY_PRIVATE=""

# Session Secret
# Secret key for session encryption.
# Required: true
# WARNING: Keep this secret! Use a strong random string.
SESSION_SECRET="YOUR_SECURE_RANDOM_STRING"

# ============================================================================
# MCP Configuration
# ============================================================================

# CMS MCP API Key
# API key for CMS Model Context Protocol integration.
# Used for the MCP endpoints
# Optional
# MCP_API_KEY="YOUR_LONG_RANDOM_TOKEN"

# ============================================================================
# Stores Configuration
# ============================================================================

# CMS Store Template ID
# Template ID for CMS store hydration.
# Required when CMS store is enabled
# CMS_STORE_TEMPLATE_ID="YOUR_ID"

# Vault Store Key
# Encryption key required when vault store is enabled.
# Required when vaultStoreUsed is true in stores_config.go
# WARNING: Keep this secret!
# VAULT_STORE_KEY="YOUR_LONG_VAULT_KEY"
